#You're looking for this:
bgrt_x1 = 0.3;
#And this too:
bgrt_y1 = 0.1815;



bgrt_image = Image("bgrt.png");
bgrt_sprite = Sprite(bgrt_image);
bgrt_sprite.SetX(Window.GetWidth() * bgrt_x1);
bgrt_sprite.SetY(Window.GetHeight() * bgrt_y1);
bgrt_sprite.SetZ(0);
bgrt_x2 = bgrt_x1 + bgrt_image.GetWidth() / Window.GetWidth();
bgrt_y2 = bgrt_y1 + bgrt_image.GetHeight() / Window.GetHeight();


bg_image = Image("background.png");
bg_sprite = Sprite(bg_image);
bg_sprite.SetX(Window.GetWidth() / 2 - bg_image.GetWidth() / 2);
bg_sprite.SetY(Window.GetHeight() / 2 - bg_image.GetHeight() / 2);
bg_sprite.SetZ(-1);
bg_sprite.SetOpacity(0);

sprites = [];
sprite_count = 0;
added = [];
fading_out = 0;

fun add_sprite(image_file, x, y) {
    img = Image(image_file);
    spr = Sprite(img);
    px = Window.GetWidth() * x - img.GetWidth() / 2;
    py = Window.GetHeight() * y - img.GetHeight() / 2;
    px = Math.Clamp(px, 0, Window.GetWidth() - img.GetWidth());
    py = Math.Clamp(py, 0, Window.GetHeight() - img.GetHeight());
    spr.SetX(px);
    spr.SetY(py);
    spr.SetZ(2);
    spr.SetOpacity(0);
    sprites[sprite_count] = spr;
    sprite_count++;
}

fun add_sprite_now(image_file, x, y) {
    img = Image(image_file);
    spr = Sprite(img);
    px = Window.GetWidth() * x - img.GetWidth() / 2;
    py = Window.GetHeight() * y - img.GetHeight() / 2;
    px = Math.Clamp(px, 0, Window.GetWidth() - img.GetWidth());
    py = Math.Clamp(py, 0, Window.GetHeight() - img.GetHeight());
    spr.SetX(px);
    spr.SetY(py);
    spr.SetZ(2);
    spr.SetOpacity(1);
    sprites[sprite_count] = spr;
    sprite_count++;
}



placed = [];
placed_count = 0;

fun is_overlapping(x, y, w, h) {
    // check bgrt
    px = Window.GetWidth() * x;
    py = Window.GetHeight() * y;
    if (px < bgrt_x2 * Window.GetWidth() && px + w > bgrt_x1 * Window.GetWidth() &&
        py < bgrt_y2 * Window.GetHeight() && py + h > bgrt_y1 * Window.GetHeight())
        return 1;
    // check other sprites
    for (i = 0; i < placed_count; i++) {
        if (px < placed[i].x + placed[i].w && px + w > placed[i].x &&
            py < placed[i].y + placed[i].h && py + h > placed[i].y)
            return 1;
    }
    return 0;
}

fun add_sprite_safe(image_file, margin) {
    img = Image(image_file);
    w = img.GetWidth();
    h = img.GetHeight();
    attempts = 0;
    local.x = Math.Random();
    local.y = Math.Random();
    while (is_overlapping(local.x, local.y, w + margin, h + margin) && attempts < 50) {
        local.x = Math.Random();
        local.y = Math.Random();
        attempts++;
    }
    if (attempts >= 50) return; // give up rather than overlap
    px = Math.Clamp(Window.GetWidth() * local.x, 0, Window.GetWidth() - w);
    py = Math.Clamp(Window.GetHeight() * local.y, 0, Window.GetHeight() - h);
    spr = Sprite(img);
    spr.SetX(px);
    spr.SetY(py);
    spr.SetZ(1);
    spr.SetOpacity(0);
    sprites[sprite_count] = spr;
    sprite_count++;
    placed[placed_count].x = px;
    placed[placed_count].y = py;
    placed[placed_count].w = w;
    placed[placed_count].h = h;
    placed_count++;
}

fun refresh_callback() {
	op = bg_sprite.GetOpacity();
	if (op < 0.3){
	    bg_sprite.SetOpacity(op + (0.3 / (30 * 50)));
	    }
    for (i = 0; i < sprite_count; i++) {
        op = sprites[i].GetOpacity();
        if (op < 1){
            sprites[i].SetOpacity(Math.Min(op + 0.02, 1));
            }
    }
    if (fading_out) {
	    black_sprite.SetOpacity(Math.Min(black_sprite.GetOpacity() + 0.02, 1));
	}
}

Plymouth.SetRefreshFunction(refresh_callback);

fun safe_random_pos() {
    local.x = Math.Random();
    local.y = Math.Random();
    while (local.x > bgrt_x1 && local.x < bgrt_x2 && local.y > bgrt_y1 && local.y < bgrt_y2) {
        local.x = Math.Random();
        local.y = Math.Random();
    }
    local.pos.x = local.x;
    local.pos.y = local.y;
    return local.pos;
}

fun BootRegular(time, progress){
