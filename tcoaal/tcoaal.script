        add_sprite("flower/" + Math.Int(Math.Random() * 10) + ".png", pos.x, pos.y);
        add_sprite_safe("BGF/" + Math.Int(Math.Random() * 5) + ".png", 20);
        global.added[6] = 1;
	}
    if (time >= 16 && !global.added[7]) {
    	pos = safe_random_pos();
        add_sprite("demon/" + Math.Int(Math.Random() * 10) + ".png", pos.x, pos.y);
        pos = safe_random_pos();
