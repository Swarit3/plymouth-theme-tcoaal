fun ShutdownRegular(time, progress) {
    #if (progress >= 0.5 && !global.fading_out)
    if (time >= 4 && !global.fading_out)
        global.fading_out = 1;
}

if (Plymouth.GetMode() == "boot"){
	for (i = 0; i < 8; i++) {
	    add_sprite("floor_bush.png", Math.Random(), 1);
	}
	for (i = 0; i < 2; i++) {
	    add_sprite("floor_tree.png", Math.Random(), 1);
	}
	for (i = 0; i < 12; i++) {
	    add_sprite("floor_twig.png", Math.Random(), 1);
	}
	
	Plymouth.SetBootProgressFunction(BootRegular);
} else if (Plymouth.GetMode() == "shutdown" || Plymouth.GetMode() == "reboot" || Plymouth.GetMode() == "suspend") {
	black_image = Image("black.png").Scale(Window.GetWidth(), Window.GetHeight());
	black_sprite = Sprite(black_image);
	black_sprite.SetX(0);
	black_sprite.SetY(0);
	black_sprite.SetZ(10);
	black_sprite.SetOpacity(0);
	for (i = 0; i < 8; i++) {
	    add_sprite_now("floor_bush.png", Math.Random(), 1);
	}
	for (i = 0; i < 2; i++) {
	    add_sprite_now("floor_tree.png", Math.Random(), 1);
	}
	for (i = 0; i < 12; i++) {
	    add_sprite_now("floor_twig.png", Math.Random(), 1);
	}
    for (i = 0; i < sprite_count; i++) {
        sprites[i].SetOpacity(1);
    }
	Plymouth.SetBootProgressFunction(ShutdownRegular);
}

status_image = Image("status/" + Plymouth.GetMode() + ".png");
status_text_image = Image("status/" + Plymouth.GetMode() + "_text.png");

status_text_image = status_text_image.Scale(status_text_image.GetWidth() / 2 , status_text_image.GetHeight() / 2);
status_image = status_image.Scale(status_image.GetWidth() * 1.5 , status_image.GetHeight() * 1.5);

total_width = status_image.GetWidth() + status_text_image.GetWidth();
start_x = (Window.GetWidth() - total_width) / 2;

status_sprite = Sprite(status_image);
status_sprite.SetX(start_x);
status_sprite.SetY(Window.GetHeight() * 0.8);
status_sprite.SetZ(0);

status_text_sprite = Sprite(status_text_image);
status_text_sprite.SetX(start_x + status_image.GetWidth());
status_text_sprite.SetY(Window.GetHeight() * 0.8);
status_text_sprite.SetZ(0);
